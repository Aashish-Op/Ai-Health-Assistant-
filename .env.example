# Clerk Configuration
# Get these keys from your Clerk Dashboard: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key
CLERK_SECRET_KEY=your_secret_key

# Clerk Redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Google Gemini API Key
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# AI Assistant rollout controls
ENABLE_RAG_HEALTH_ASSISTANT=false
MEDICAL_KNOWLEDGE_MAX_DOCUMENTS=2500
ENABLE_VOICE_ASSISTANT=false

# ElevenLabs Text-to-Speech
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Firebase Configuration
# Get these from Firebase Console -> Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Clinical Copilot Backend
# Async SQLAlchemy PostgreSQL URL used by FastAPI and Alembic.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/clinical_copilot
# Runtime environment: development | staging | production.
ENVIRONMENT=development
# Backend logging level.
LOG_LEVEL=INFO
# Secret used by future auth/session work. Replace outside development.
SECRET_KEY=change-me-in-production
# JSON list of frontend origins allowed to call the backend.
CORS_ORIGINS=["http://localhost:3000"]
# Phase 4 LLM provider key. Leave blank for Phase 1.
ANTHROPIC_API_KEY=
# Phase 2+ embeddings/retrieval key. Put the real key in .env, not this template.
OPENAI_API_KEY=
# Phase 2 vector database key. Put the real key in .env, not this template.
PINECONE_API_KEY=
# Pinecone serverless index name.
PINECONE_INDEX_NAME=clinical-copilot
# Pinecone cloud/region label used for project configuration.
PINECONE_ENVIRONMENT=us-east-1-aws
# Phase 2 reranker key. Put the real key in .env, not this template.
COHERE_API_KEY=
# Phase 2 PubMed contact email for NCBI E-utilities.
NCBI_EMAIL=you@university.edu
# Optional PubMed API key for higher NCBI rate limits.
NCBI_API_KEY=
# Retrieval tuning defaults.
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
RERANKER_MODEL=rerank-v3.5
RERANKER_TOP_N=5
RETRIEVAL_TOP_K=20
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=50
PUBMED_MAX_PER_QUERY=200
